<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">magic_survey_form.magic_survey_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Survey Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="Magic\Survey\Block\Adminhtml\Survey\Edit\BackButton"/>
            <button name="delete" class="Magic\Survey\Block\Adminhtml\Survey\Edit\DeleteButton"/>
            <button name="save_and_continue" class="Magic\Survey\Block\Adminhtml\Survey\Edit\SaveAndContinueButton"/>
            <button name="save" class="Magic\Survey\Block\Adminhtml\Survey\Edit\SaveButton"/>
        </buttons>
        <namespace>magic_survey_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>magic_survey_form.magic_survey_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="magic_survey_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="magicsurvey/survey/save"/>
        </settings>
        <dataProvider class="Magic\Survey\Model\Survey\DataProvider" name="magic_survey_form_data_source">
            <settings>
                <requestFieldName>survey_id</requestFieldName>
                <primaryFieldName>survey_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Survey Details</label>
        </settings>

        <field name="survey_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>

        <field name="title" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Survey Title</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="description" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Description</label>
            </settings>
        </field>

        <field name="status" formElement="select">
            <settings>
                <dataType>select</dataType>
                <label translate="true">Status</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magic\Survey\Model\Config\Source\Status"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="start_date" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Start Date</label>
            </settings>
        </field>

        <field name="end_date" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">End Date</label>
            </settings>
        </field>

    </fieldset>

</form>
