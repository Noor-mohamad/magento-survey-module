<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Survey table -->
    <table name="magic_survey" resource="default" engine="innodb" comment="Surveys">
        <column xsi:type="int" name="survey_id" unsigned="true" nullable="false" identity="true" comment="Survey ID"/>
        <column xsi:type="varchar" length="255" name="title" nullable="false" comment="Title"/>
        <column xsi:type="text" name="description" nullable="true" comment="Description"/>
        <column xsi:type="smallint" name="status" unsigned="true" nullable="false" default="1" comment="Status"/>
        <column xsi:type="date" name="start_date" nullable="true" comment="Start Date"/>
        <column xsi:type="date" name="end_date" nullable="true" comment="End Date"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="survey_id"/>
        </constraint>
    </table>

    <!-- Survey Questions table -->
    <table name="magic_survey_question" resource="default" engine="innodb" comment="Survey Questions">
        <column xsi:type="int" name="question_id" unsigned="true" nullable="false" identity="true" comment="Question ID"/>
        <column xsi:type="int" name="survey_id" unsigned="true" nullable="false" comment="Survey ID"/>
        <column xsi:type="text" name="title" nullable="false" comment="Question Title"/>
        <column xsi:type="varchar" length="50" name="type" nullable="false" default="radio" comment="Question Type: radio, checkbox, dropdown, text"/>
        <column xsi:type="smallint" name="is_required" unsigned="true" nullable="false" default="0" comment="Is Required"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="question_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGIC_SURVEY_QUESTION_SURVEY_ID"
                    table="magic_survey_question" column="survey_id"
                    referenceTable="magic_survey" referenceColumn="survey_id"
                    onDelete="CASCADE"/>
        <index referenceId="MAGIC_SURVEY_QUESTION_SURVEY_ID" indexType="btree">
            <column name="survey_id"/>
        </index>
    </table>

    <!-- Answer Options table (for radio / checkbox / dropdown questions) -->
    <table name="magic_survey_answer_option" resource="default" engine="innodb" comment="Survey Answer Options">
        <column xsi:type="int" name="option_id" unsigned="true" nullable="false" identity="true" comment="Option ID"/>
        <column xsi:type="int" name="question_id" unsigned="true" nullable="false" comment="Question ID"/>
        <column xsi:type="varchar" length="255" name="label" nullable="false" comment="Option Label"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="option_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGIC_SURVEY_ANSWER_OPTION_QUESTION_ID"
                    table="magic_survey_answer_option" column="question_id"
                    referenceTable="magic_survey_question" referenceColumn="question_id"
                    onDelete="CASCADE"/>
        <index referenceId="MAGIC_SURVEY_ANSWER_OPTION_QUESTION_ID" indexType="btree">
            <column name="question_id"/>
        </index>
    </table>

    <!-- Customer Responses table -->
    <table name="magic_survey_response" resource="default" engine="innodb" comment="Survey Responses">
        <column xsi:type="int" name="response_id" unsigned="true" nullable="false" identity="true" comment="Response ID"/>
        <column xsi:type="int" name="survey_id" unsigned="true" nullable="false" comment="Survey ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true" comment="Customer ID"/>
        <column xsi:type="varchar" length="255" name="customer_email" nullable="true" comment="Customer Email"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="true" comment="Order ID"/>
        <column xsi:type="timestamp" name="submitted_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Submitted At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="response_id"/>
        </constraint>
        <index referenceId="MAGIC_SURVEY_RESPONSE_SURVEY_ID" indexType="btree">
            <column name="survey_id"/>
        </index>
    </table>

    <!-- Response Details (per-question answers) -->
    <table name="magic_survey_response_detail" resource="default" engine="innodb" comment="Survey Response Details">
        <column xsi:type="int" name="detail_id" unsigned="true" nullable="false" identity="true" comment="Detail ID"/>
        <column xsi:type="int" name="response_id" unsigned="true" nullable="false" comment="Response ID"/>
        <column xsi:type="int" name="question_id" unsigned="true" nullable="false" comment="Question ID"/>
        <column xsi:type="int" name="option_id" unsigned="true" nullable="true" comment="Selected Option ID"/>
        <column xsi:type="text" name="answer_text" nullable="true" comment="Free Text Answer"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="detail_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGIC_SURVEY_RESPONSE_DETAIL_RESPONSE_ID"
                    table="magic_survey_response_detail" column="response_id"
                    referenceTable="magic_survey_response" referenceColumn="response_id"
                    onDelete="CASCADE"/>
        <index referenceId="MAGIC_SURVEY_RESPONSE_DETAIL_RESPONSE_ID" indexType="btree">
            <column name="response_id"/>
        </index>
    </table>

</schema>
